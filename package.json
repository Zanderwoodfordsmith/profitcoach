{
  "name": "profit-coach-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:webpack": "next dev --webpack",
    "dev:clean": "rm -rf .next node_modules/.cache && next dev",
    "dev:clean:webpack": "rm -rf .next node_modules/.cache && next dev --webpack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "sync-playbooks": "npx tsx scripts/sync-playbooks-from-md.ts",
    "backfill-coach-geocodes": "npx tsx scripts/backfill-coach-geocodes.ts",
    "backfill-stripe-payments": "npx tsx scripts/backfill-stripe-payments.ts",
    "import-stripe-payments": "npx tsx scripts/import-stripe-payments-from-csv.ts",
    "import-revolut-payments": "npx tsx scripts/import-revolut-payments-from-csv.ts",
    "import-revolut-direct-payments": "npx tsx scripts/import-revolut-direct-payments-from-csv.ts",
    "import-disco-members": "npx tsx scripts/import-disco-members-from-csv.ts",
    "import-sales-robot-customers": "npx tsx scripts/import-sales-robot-customers-from-csv.ts",
    "import-member-avatars": "npx tsx scripts/import-member-avatars-from-folder.ts",
    "import-academy-lessons": "npx tsx scripts/import-academy-lessons-from-drive-folder.ts",
    "import-academy-suggested": "npx tsx scripts/import-academy-lessons-from-drive-folder.ts --apply --accept-suggested 0.36 --include-ambiguous --skip-existing --continue-on-error --write-suggested-overrides",
    "import-academy-suggested:dry-run": "npx tsx scripts/import-academy-lessons-from-drive-folder.ts --dry-run --accept-suggested 0.36 --include-ambiguous --write-suggested-overrides",
    "import-academy-resources": "npx tsx scripts/import-academy-resources-from-markdown.ts",
    "import-academy-bodies:dry-run": "npx tsx scripts/import-academy-lesson-bodies-from-docs.ts --dry-run",
    "import-academy-bodies": "npx tsx scripts/import-academy-lesson-bodies-from-docs.ts --apply",
    "dedupe-academy-resources": "npx tsx scripts/dedupe-academy-resources.ts",
    "clean-academy-transcripts": "npx tsx scripts/clean-academy-transcript-speakers.ts",
    "normalize-academy-lessons:dry-run": "npx tsx scripts/normalize-academy-lesson-markdown.ts --dry-run",
    "normalize-academy-lessons": "npx tsx scripts/normalize-academy-lesson-markdown.ts --apply",
    "import-community-posts": "npx tsx scripts/import-community-posts-from-csv.ts",
    "export-boss-questions-csv": "npx tsx scripts/export-boss-methodology-questions-csv.ts",
    "find-duplicate-coaches": "npx tsx scripts/find-duplicate-coaches.ts",
    "merge-duplicate-coaches": "npx tsx scripts/merge-duplicate-coaches.ts",
    "merge-duplicate-coaches:dry-run": "npx tsx scripts/merge-duplicate-coaches.ts --dry-run",
    "match-coach-roster": "npx tsx scripts/match-coach-success-roster.ts",
    "import-stripe-payments:legacy": "npx tsx scripts/import-stripe-payments-from-csv.ts --legacy-products",
    "import-clickup-join-dates": "npx tsx scripts/import-clickup-coach-join-dates-from-csv.ts",
    "import-clickup-join-dates:dry-run": "npx tsx scripts/import-clickup-coach-join-dates-from-csv.ts --dry-run",
    "import-historical-coaches": "npx tsx scripts/import-historical-coaches-from-clickup-csv.ts",
    "import-historical-coaches:dry-run": "npx tsx scripts/import-historical-coaches-from-clickup-csv.ts --dry-run",
    "backfill-join-dates-from-payments": "npx tsx scripts/backfill-coach-join-dates-from-payments.ts",
    "reassign-unassigned-payments": "npx tsx scripts/reassign-unassigned-payments.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@supabase/supabase-js": "^2.48.0",
    "@vercel/speed-insights": "^2.0.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.562.0",
    "luxon": "^3.7.2",
    "marked": "^18.0.4",
    "next": "16.1.6",
    "pdf-lib": "^1.17.1",
    "qrcode": "^1.5.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-leaflet": "^5.0.0",
    "react-leaflet-cluster": "^4.1.3",
    "react-markdown": "^10.1.0",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "stripe": "^22.1.1",
    "turndown": "^7.2.4",
    "undici": "^8.2.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/leaflet": "^1.9.21",
    "@types/leaflet.markercluster": "^1.5.6",
    "@types/luxon": "^3.7.1",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/turndown": "^5.0.6",
    "csv-parse": "^5.6.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
